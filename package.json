{
  "name": "oyamel",
  "version": "0.1.0",
  "description": "Sync unsyncable financial data to Monarch Money",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "oyamel": "./bin/oyamel.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli.ts",
    "cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "monarch-money",
    "finance",
    "transactions",
    "pdf-parser",
    "coinbase",
    "cli"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Brandon Wolfe",
  "repository": {
    "type": "git",
    "url": "https://github.com/Wolfe1/oyamel.git"
  },
  "homepage": "https://github.com/Wolfe1/oyamel#readme",
  "bugs": {
    "url": "https://github.com/Wolfe1/oyamel/issues"
  },
  "license": "MIT",
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "pdfjs-dist": "^5.5.207",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
